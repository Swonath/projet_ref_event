{% extends 'locataire/base_dashboard.html.twig' %}

{% block title %}Paiement - Références Événements{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .checkout-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .checkout-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-top: 24px;
        }

        .checkout-card {
            background: white;
            border-radius: 12px;
            padding: 32px;
        }

        .checkout-card h3 {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 20px;
        }

        .emplacement-info {
            display: flex;
            gap: 16px;
            margin-bottom: 24px;
            padding-bottom: 24px;
            border-bottom: 1px solid #e5e5e5;
        }

        .emplacement-info-image {
            width: 100px;
            height: 75px;
            border-radius: 8px;
            overflow: hidden;
            flex-shrink: 0;
        }

        .emplacement-info-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .emplacement-info-details h4 {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 4px;
        }

        .emplacement-info-details p {
            color: #666;
            font-size: 14px;
            margin: 0;
        }

        .dates-info {
            background: #f8f9fa;
            padding: 16px;
            border-radius: 8px;
            margin-bottom: 24px;
        }

        .dates-info p {
            margin: 8px 0;
            display: flex;
            justify-content: space-between;
        }

        .dates-info strong {
            font-weight: 600;
        }

        .price-table {
            margin-bottom: 24px;
        }

        .price-row {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            color: #666;
        }

        .price-row.subtotal {
            border-top: 1px solid #e5e5e5;
            margin-top: 8px;
            padding-top: 16px;
            font-weight: 600;
            color: #1a1a1a;
        }

        .price-row.total {
            border-top: 2px solid #e5e5e5;
            margin-top: 12px;
            padding-top: 16px;
            font-size: 20px;
            font-weight: 700;
            color: #1976d2;
        }

        .security-badge {
            background: #e3f2fd;
            padding: 12px;
            border-radius: 8px;
            text-align: center;
            color: #1565c0;
            font-size: 13px;
        }

        .payment-form {
            margin-top: 24px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            font-weight: 600;
            margin-bottom: 8px;
            color: #1a1a1a;
        }

        .form-group input {
            width: 100%;
            padding: 12px;
            border: 1px solid #e5e5e5;
            border-radius: 8px;
            font-size: 14px;
        }

        .form-group input:focus {
            outline: none;
            border-color: #1976d2;
        }

        #card-element {
            padding: 16px;
            border: 1px solid #e5e5e5;
            border-radius: 8px;
            background: white;
        }

        #card-errors {
            color: #d32f2f;
            margin-top: 12px;
            font-size: 14px;
        }

        .btn-pay {
            width: 100%;
            padding: 16px;
            background: #1976d2;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 24px;
        }

        .btn-pay:hover:not(:disabled) {
            background: #1565c0;
        }

        .btn-pay:disabled {
            background: #ccc;
            cursor: not-allowed;
        }

        .stripe-badge {
            text-align: center;
            margin-top: 16px;
            color: #666;
            font-size: 12px;
        }

        .info-box {
            background: #fff3cd;
            border-left: 4px solid #ffc107;
            padding: 16px;
            border-radius: 8px;
            margin-bottom: 24px;
            color: #856404;
        }

        .info-box strong {
            display: block;
            margin-bottom: 8px;
        }

        @media (max-width: 968px) {
            .checkout-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block dashboard_content %}

<div class="checkout-container">
    <div class="page-header" style="margin-bottom: 24px;">
        <h1 class="page-title">Paiement sécurisé</h1>
        <p class="page-subtitle">Finalisez votre réservation</p>
    </div>

    <div class="checkout-grid">
        <!-- Colonne gauche: Résumé de la réservation -->
        <div class="checkout-card">
            <h3>Récapitulatif de votre réservation</h3>

            <!-- Informations de l'emplacement -->
            <div class="emplacement-info">
                <div class="emplacement-info-image">
                    {% if emplacement.photos is not empty %}
                        <img src="{{ asset('uploads/photos/' ~ emplacement.photos|first.cheminFichier) }}" alt="{{ emplacement.titreAnnonce }}">
                    {% else %}
                        <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; background:#f5f5f5;">
                            📷
                        </div>
                    {% endif %}
                </div>
                <div class="emplacement-info-details">
                    <h4>{{ emplacement.titreAnnonce }}</h4>
                    <p>{{ emplacement.centreCommercial.nomCentre }}</p>
                    <p>{{ emplacement.centreCommercial.ville }}</p>
                </div>
            </div>

            <!-- Dates de réservation -->
            <div class="dates-info">
                <p>
                    <span>Date de début :</span>
                    <strong>{{ dateDebut|date('d/m/Y') }}</strong>
                </p>
                <p>
                    <span>Date de fin :</span>
                    <strong>{{ dateFin|date('d/m/Y') }}</strong>
                </p>
                <p>
                    <span>Durée :</span>
                    <strong>{{ prices.days }} jour(s)</strong>
                </p>
            </div>

            <!-- Détail des prix -->
            <div class="price-table">
                <div class="price-row">
                    <span>Location (HT)</span>
                    <span>{{ prices.montantLocation|number_format(2, ',', ' ') }} €</span>
                </div>
                <div class="price-row">
                    <span>Commission plateforme (25%)</span>
                    <span>{{ prices.montantCommission|number_format(2, ',', ' ') }} €</span>
                </div>
                <div class="price-row">
                    <span>TVA (20%)</span>
                    <span>{{ prices.montantTVA|number_format(2, ',', ' ') }} €</span>
                </div>
                <div class="price-row subtotal">
                    <span>Sous-total TTC</span>
                    <span>{{ prices.montantTotal|number_format(2, ',', ' ') }} €</span>
                </div>
                <div class="price-row">
                    <span>Caution</span>
                    <span>{{ prices.caution|number_format(2, ',', ' ') }} €</span>
                </div>
                <div class="price-row total">
                    <span>Total à payer</span>
                    <span>{{ prices.montantTotalAvecCaution|number_format(2, ',', ' ') }} €</span>
                </div>
            </div>

            <div class="info-box">
                <strong>ℹ️ À propos de la caution</strong>
                La caution sera restituée à la fin de votre location si aucun dégât n'est constaté.
            </div>

            <div class="security-badge">
                🔒 Paiement sécurisé SSL - Vos données sont protégées
            </div>
        </div>

        <!-- Colonne droite: Formulaire de paiement -->
        <div class="checkout-card">
            <h3>Informations de paiement</h3>

            <form id="payment-form">
                <div class="form-group">
                    <label for="cardholder-name">Nom sur la carte *</label>
                    <input type="text" id="cardholder-name" name="cardholder-name" required placeholder="Jean Dupont">
                </div>

                <div class="form-group">
                    <label>Informations de carte bancaire *</label>
                    <div id="card-element"></div>
                    <div id="card-errors" role="alert"></div>
                </div>

                <button type="submit" class="btn-pay" id="submit-button" disabled>
                    Payer {{ prices.montantTotalAvecCaution|number_format(2, ',', ' ') }} €
                </button>

                <div class="stripe-badge">
                    Paiement sécurisé par
                    <svg style="height: 20px; width: auto; vertical-align: middle; margin-left: 4px;" viewBox="0 0 60 25" xmlns="http://www.w3.org/2000/svg">
                        <path fill="#635BFF" d="M59.64 14.28h-8.06c.19 1.93 1.6 2.55 3.2 2.55 1.64 0 2.96-.37 4.05-.95v3.32a8.33 8.33 0 0 1-4.56 1.1c-4.01 0-6.83-2.5-6.83-7.48 0-4.19 2.39-7.52 6.3-7.52 3.92 0 5.96 3.28 5.96 7.5 0 .4-.04 1.26-.06 1.48zm-5.92-5.62c-1.03 0-2.17.73-2.17 2.58h4.25c0-1.85-1.07-2.58-2.08-2.58zM40.95 20.3c-1.44 0-2.32-.6-2.9-1.04l-.02 4.63-4.12.87V5.57h3.76l.08 1.02a4.7 4.7 0 0 1 3.23-1.29c2.9 0 5.62 2.6 5.62 7.4 0 5.23-2.7 7.6-5.65 7.6zM40 8.95c-.95 0-1.54.34-1.97.81l.02 6.12c.4.44.98.78 1.95.78 1.52 0 2.54-1.65 2.54-3.87 0-2.15-1.04-3.84-2.54-3.84zM28.24 5.57h4.13v14.44h-4.13V5.57zm0-4.7L32.37 0v3.36l-4.13.88V.88zm-4.32 9.35v9.79H19.8V5.57h3.7l.12 1.22c1-1.77 3.07-1.41 3.62-1.22v3.79c-.52-.17-2.29-.43-3.32.86zm-8.55 4.72c0 2.43 2.6 1.68 3.12 1.46v3.36c-.55.3-1.54.54-2.89.54a4.15 4.15 0 0 1-4.27-4.24l.01-13.17 4.02-.86v3.54h3.14V9.1h-3.13v5.85zm-4.91.7c0 2.97-2.31 4.66-5.73 4.66a11.2 11.2 0 0 1-4.46-.93v-3.93c1.38.75 3.1 1.31 4.46 1.31.92 0 1.53-.24 1.53-1C6.26 13.77 0 14.51 0 9.95 0 7.04 2.28 5.3 5.62 5.3c1.36 0 2.72.2 4.09.75v3.88a9.23 9.23 0 0 0-4.1-1.06c-.86 0-1.44.25-1.44.93 0 1.85 6.29.97 6.29 5.88z" fill-rule="evenodd"/>
                    </svg>
                </div>

                <div style="text-align: center; margin-top: 16px;">
                    <a href="{{ path('locataire_reservation_cancel') }}" style="color: #666; text-decoration: none; font-size: 14px;">
                        Annuler la réservation
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://js.stripe.com/v3/"></script>
    <script>
        // Initialiser Stripe
        const stripe = Stripe('{{ stripe_public_key }}');
        const elements = stripe.elements();

        // Créer l'élément Card
        const cardElement = elements.create('card', {
            style: {
                base: {
                    fontSize: '16px',
                    color: '#1a1a1a',
                    '::placeholder': {
                        color: '#999',
                    },
                },
                invalid: {
                    color: '#d32f2f',
                },
            },
        });

        cardElement.mount('#card-element');

        // Gérer les changements de carte (validation)
        cardElement.on('change', (event) => {
            const displayError = document.getElementById('card-errors');
            const submitButton = document.getElementById('submit-button');

            if (event.error) {
                displayError.textContent = event.error.message;
                submitButton.disabled = true;
            } else {
                displayError.textContent = '';
                submitButton.disabled = false;
            }
        });

        // Gérer la soumission du formulaire
        const form = document.getElementById('payment-form');
        form.addEventListener('submit', async (event) => {
            event.preventDefault();

            const submitButton = document.getElementById('submit-button');
            const cardholderName = document.getElementById('cardholder-name').value;

            if (!cardholderName) {
                alert('Veuillez entrer le nom sur la carte');
                return;
            }

            // Désactiver le bouton
            submitButton.disabled = true;
            submitButton.textContent = 'Traitement en cours...';

            try {
                // 1. Créer le Payment Intent
                const response = await fetch('{{ path('locataire_reservation_payment_intent') }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': '{{ csrf_token('payment-intent') }}'
                    }
                });

                const data = await response.json();

                if (data.error) {
                    throw new Error(data.error);
                }

                // 2. Confirmer le paiement avec Stripe
                const { error, paymentIntent } = await stripe.confirmCardPayment(data.clientSecret, {
                    payment_method: {
                        card: cardElement,
                        billing_details: {
                            name: cardholderName
                        }
                    }
                });

                if (error) {
                    // Afficher l'erreur
                    document.getElementById('card-errors').textContent = error.message;
                    submitButton.disabled = false;
                    submitButton.textContent = 'Payer {{ prices.montantTotalAvecCaution|number_format(2, ',', ' ') }} €';
                } else if (paymentIntent.status === 'succeeded') {
                    // 3. Confirmer la réservation côté serveur
                    const confirmForm = document.createElement('form');
                    confirmForm.method = 'POST';
                    confirmForm.action = '{{ path('locataire_reservation_confirm') }}';

                    const paymentIntentInput = document.createElement('input');
                    paymentIntentInput.type = 'hidden';
                    paymentIntentInput.name = 'payment_intent_id';
                    paymentIntentInput.value = paymentIntent.id;
                    confirmForm.appendChild(paymentIntentInput);

                    const csrfInput = document.createElement('input');
                    csrfInput.type = 'hidden';
                    csrfInput.name = '_token';
                    csrfInput.value = '{{ csrf_token('confirm-reservation') }}';
                    confirmForm.appendChild(csrfInput);

                    document.body.appendChild(confirmForm);
                    confirmForm.submit();
                }
            } catch (err) {
                console.error(err);
                document.getElementById('card-errors').textContent = err.message || 'Une erreur est survenue. Veuillez réessayer.';
                submitButton.disabled = false;
                submitButton.textContent = 'Payer {{ prices.montantTotalAvecCaution|number_format(2, ',', ' ') }} €';
            }
        });
    </script>
{% endblock %}
